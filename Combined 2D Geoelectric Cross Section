import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import matplotlib.patches as patches

def plot_combined_xsection(layers, colour_func, thresholds, title='',
                           xlim=None, ylim=None, water_table_depth=None):
    """
    Build a 2D geoelectric cross‑section with:
    - colour‑coded resistivity blocks
    - station names and distances
    - resistivity values inside each block
    - water table line (optional)
    - colour legend

    layers : dict of station_name -> {
             'dist': float (m),
             'rho': [list of resistivities in Ωm],
             'thick': [list of thicknesses in m, None for half‑space]
             }
    colour_func : function(rho) -> hex colour
    thresholds : list of resistivity bounds for legend
    water_table_depth : depth (m) to draw dashed water table line (optional)
    """
    fig, ax = plt.subplots(figsize=(12, 6))
    column_width = 12            # width of each station block in metres on the x‑axis
    max_depth = 5                # initial guess; will be expanded

    # ---- gather legend handles ----
    legend_patches = []
    for i in range(len(thresholds)-1):
        mid_rho = (thresholds[i] + thresholds[i+1]) / 2
        label = f'{thresholds[i]}‑{thresholds[i+1]} Ωm'
        legend_patches.append(mpatches.Patch(color=colour_func(mid_rho), label=label))

    # ---- draw each station ----
    for name, data in layers.items():
        x0 = data['dist'] - column_width/2   # centre block on distance
        cum_depth = 0.0
        for rho, thick in zip(data['rho'], data['thick']):
            if thick is None:
                thick = 8.0   # placeholder for basement half‑space
            rect = patches.Rectangle(
                (x0, cum_depth), column_width, thick,
                facecolor=colour_func(rho),
                edgecolor='black', linewidth=1.0
            )
            ax.add_patch(rect)

            # resistivity label inside block
            ax.text(x0 + column_width/2, cum_depth + thick/2,
                    f'{rho} Ωm', ha='center', va='center',
                    fontsize=8, color='white', weight='bold')
            cum_depth += thick
        max_depth = max(max_depth, cum_depth)

        # Station name and distance below the block
        ax.text(x0 + column_width/2, cum_depth + 0.3,
                f'{name}\n({data["dist"]} m)', ha='center', va='top',
                fontsize=9, weight='bold')

    # ---- water table (if given) ----
    if water_table_depth is not None:
        ax.axhline(y=water_table_depth, color='cyan', linestyle='--',
                   linewidth=1.5, label='Inferred water table')
        # add water table to legend
        from matplotlib.lines import Line2D
        legend_patches.append(Line2D([0], [0], color='cyan', linestyle='--',
                                     label='Water table'))

    # ---- axes and styling ----
    ax.set_xlim(min(l['dist'] for l in layers.values()) - column_width/2 - 5,
                max(l['dist'] for l in layers.values()) + column_width/2 + 5)
    ax.set_ylim(max_depth + 2, 0)
    ax.set_xlabel('Distance from dumpsite core (m)')
    ax.set_ylabel('Depth (m)')
    ax.set_title(title)

    # add distance ticks
    dist_values = [l['dist'] for l in layers.values()]
    ax.set_xticks(dist_values)
    ax.set_xticklabels([f'{d} m' for d in dist_values])

    # legend outside plot
    ax.legend(handles=legend_patches, bbox_to_anchor=(1.04, 1), loc='upper left')
    plt.tight_layout(rect=[0, 0, 0.88, 1])   # leave space for legend
    plt.show()


