import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as patches

def plot_xsection(layers, colour_func, title='Geoelectric Cross‑Section',
                  xlim=None, ylim=None):
    """
    layers : dict of station_name -> {'dist': x, 'rho': [list], 'thick': [list]}
    colour_func : function(rho) -> colour
    """
    fig, ax = plt.subplots(figsize=(14, 7))
    column_width = 18

    for name, data in layers.items():
        x0 = data['dist']
        cum_depth = 0.0
        for rho, thick in zip(data['rho'], data['thick']):
            if thick is None:
                thick = 8.0
            rect = patches.Rectangle(
                (x0, cum_depth), column_width, thick,
                facecolor=colour_func(rho), edgecolor='black', linewidth=1
            )
            ax.add_patch(rect)
            ax.text(x0 + column_width/2, cum_depth + thick/2,
                    f'{rho} Ωm', ha='center', va='center', fontsize=8, color='white')
            cum_depth += thick
        ax.text(x0 + column_width/2, -0.5, name, ha='center', fontsize=9)

    if xlim:
        ax.set_xlim(xlim)
    if ylim:
        ax.set_ylim(ylim)
    else:
        ax.invert_yaxis()
    ax.set_xlabel('Distance (m)')
    ax.set_ylabel('Depth (m)')
    ax.set_title(title)
    plt.tight_layout()
    plt.show()

