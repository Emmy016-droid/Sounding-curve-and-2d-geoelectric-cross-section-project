def my_colour(rho):
    if rho < 10:
        return '#1a0033'
    elif rho < 30:
        return '#6a1b9a'
    elif rho < 80:
        return '#ab47bc'
    elif rho < 200:
        return '#1565c0'
    else:
        return '#1b5e20'

