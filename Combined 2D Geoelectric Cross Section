# Resistivity colour map: edit the thresholds and colours to match your geology
def my_colour(rho):
    if rho < 10:
        return '#1a0033'    # dark purple – severe leachate
    elif rho < 30:
        return '#6a1b9a'    # purple – moderate contamination
    elif rho < 80:
        return '#ab47bc'    # light purple – slight contamination
    elif rho < 200:
        return '#1565c0'    # blue – weathered basement
    else:
        return '#1b5e20'    # green – fresh basement

THRESHOLDS = [0, 10, 30, 80, 200, 1000]   # must have one more than number of colours

# ---- Station data – edit distances, resistivities, and thicknesses ----
STATIONS = {
    # VES 1 is the dumpsite core at 0 m
    'VES 1 (Core)': {'dist': 0,   'rho': [8, 5, 20, 80],       'thick': [1.5, 4.0, 10.0, None]},
    'VES 2':        {'dist': 25,  'rho': [14, 10, 30, 120],     'thick': [0.5, 3.0, 10.0, None]},
    'VES 3':        {'dist': 50,  'rho': [22.9, 30, 62],        'thick': [1.0, 6.0, None]},
    'VES 4':        {'dist': 75,  'rho': [15.2, 22.7, 149.2],   'thick': [1.0, 10.0, None]},
    'VES 5':        {'dist': 100, 'rho': [13, 17.4, 63],        'thick': [1.0, 10.0, None]},
}

WATER_TABLE = 15.5   # depth in metres (set to None to hide)

# =========================================================================
# Call the plotting function
# =========================================================================
plot_combined_xsection(
    layers=STATIONS,
    colour_func=my_colour,
    thresholds=THRESHOLDS,
    title='2D Geoelectric Cross‑Section – Contaminated Profile (VES 1–VES 5)',
    water_table_depth=WATER_TABLE
)
