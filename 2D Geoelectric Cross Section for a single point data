def my_colour(rho):
    # Uncontaminated site – use a green scale
    if rho < 400:
        return '#a5d6a7'   # light green
    elif rho < 800:
        return '#66bb6a'   # mid green
    else:
        return '#2e7d32'   # dark green – high resistivity

THRESHOLDS = [0, 400, 800, 2000]
LABELS = ['<400 Ωm', '400-800 Ωm', '>800 Ωm']

DATA = {
    'Control': {
        'dist': 0,
        'rho': [831, 773, 857, 247],
        'thick': [2.0, 3.0, 10.0, None]
    }
}

plot_control_xsection(DATA, my_colour, THRESHOLDS, LABELS,
                      title='Control Point Geoelectric Cross‑Section',
                      xlim=(-5, 25), ylim=(30, 0))
