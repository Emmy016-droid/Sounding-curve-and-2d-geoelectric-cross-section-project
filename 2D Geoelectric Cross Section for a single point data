import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import matplotlib.patches as patches

def plot_control_xsection(layers, colour_func, thresholds, colour_labels,
                          title='Control Point Cross‑Section', xlim=None, ylim=None):
    fig, ax = plt.subplots(figsize=(8, 6))
    column_width = 15

    # Legend patches
    legend_patches = [
        mpatches.Patch(color=colour_func((thresholds[i]+thresholds[i+1])/2),
                       label=f'{thresholds[i]}-{thresholds[i+1]} Ωm')
        for i in range(len(thresholds)-1)
    ]

    for name, data in layers.items():
        x0 = data['dist']
        cum_depth = 0.0
        # Assuming 'rho' and 'thick' are lists within data
        for rho, thick in zip(data['rho'], data['thick']):
            if thick is None:
                thick = 8.0 # Default thickness if None
            rect = patches.Rectangle(
                (x0, cum_depth), column_width, thick,
                facecolor=colour_func(rho), edgecolor='black'
            )
            ax.add_patch(rect)
            ax.text(x0 + column_width/2, cum_depth + thick/2,
                    f'{rho} Ωm', ha='center', va='center', fontsize=8, color='white')
            cum_depth += thick

    ax.legend(handles=legend_patches, bbox_to_anchor=(1.02, 1), loc='upper left')

    if xlim:
        ax.set_xlim(xlim)
    if ylim:
        ax.set_ylim(ylim)
    else:
        ax.invert_yaxis() # Invert y-axis to show depth increasing downwards
    ax.set_xlabel('Distance (m)')
    ax.set_ylabel('Depth (m)')
    ax.set_title(title)
    plt.tight_layout()
    plt.show()

